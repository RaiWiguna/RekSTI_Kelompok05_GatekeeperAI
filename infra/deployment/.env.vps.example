NODE_ENV=production

# Public API host used by frontend (example only, not read directly by API runtime)
PUBLIC_API_BASE_URL=https://api.example.com/v1

# API runtime
API_PORT=3001
WEB_PORT=3000
IOT_GATEWAY_PORT=3002
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://yourdomain.com
JWT_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-long-random-string
SIX_SYNC_CRON=0 0 * * *
FACE_SERVICE_URL=http://face-recognition:8000

# Compose infra credentials
POSTGRES_DB=gatekeeper
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password

# Internal service URLs (used by API)
DATABASE_URL=postgresql://postgres:replace-with-strong-password@postgres:5432/gatekeeper
REDIS_URL=redis://redis:6379
