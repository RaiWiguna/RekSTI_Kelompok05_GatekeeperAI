{
  "name": "gatekeeper-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web:stack": "node scripts/dev-stack.mjs web",
    "dev:mobile:stack": "node scripts/dev-stack.mjs mobile",
    "dev:mobile:stack:android": "node scripts/dev-stack.mjs mobile android",
    "dev:mobile:stack:device": "node scripts/dev-stack.mjs mobile device",
    "dev:mobile:stack:localhost": "node scripts/dev-stack.mjs mobile localhost",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:format": "prisma format --schema infra/database/schema.prisma",
    "db:validate": "prisma validate --schema infra/database/schema.prisma",
    "db:generate": "prisma generate --schema infra/database/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema infra/database/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema infra/database/schema.prisma",
    "db:seed": "node infra/database/seed.mjs"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "prisma"
    ]
  }
}
